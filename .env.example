# Database Configuration
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=diagnostyka_db
DB_PORT=5432
DB_SSLMODE=disable
DB_TIMEZONE=Europe/Warsaw

# Security
# JWT_SECRET should be a long, random string
JWT_SECRET=your_jwt_secret_here

# AES_KEY must be exactly 64 hex characters (32 bytes) for AES-256-GCM
# Example: 61122b0510e39e95735f9d4d3f34b8f4afae15e5015c5576b6c772fe30d0a265
AES_KEY=your_64_char_hex_key_here

# Email Configuration
EMAILS_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# Application Settings
# This is used for generating QR code links and emails
APP_URL=http://localhost:4200
